# Dépendances
/node_modules
/.pnp
.pnp.*

# Build / sorties (régénérées)
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# Secrets / variables d'environnement (seul .env.example est versionné)
.env
.env.*
!.env.example

# Atelier de données — LOCAL uniquement, JAMAIS dans Git.
# Bundles bruts, extraction, parsing, outils, images en attente d'upload R2.
# Régénérables depuis le jeu / sauvegardés sur R2 (cf. datagen/README.md).
/.gamedata/
# Sortie de `datagen:build` = la PROPOSITION (non validée). Seul
# `data/generated/` (via `pnpm datagen:promote`) est committé et servi.
/data/extracted/

# Tests / couverture
/coverage

# Rapports d'audit Unlighthouse (régénérés à la demande)
/.unlighthouse/

# Logs
*.log
npm-debug.log*
yarn-error.log*

# OS / éditeurs
.DS_Store
Thumbs.db
desktop.ini
*.swp
.idea/
.assets-staging/
# Pool éditorial (médias faits main, ex. wallpapers Outerpedia) — gros binaires
# poussés sur R2 comme le reste, jamais dans git. Source durable = R2 + originaux.
.editorial/
docs/seo&audit
# Dumps SQL locaux (migration ponctuelle) — jamais commites
*.sql
