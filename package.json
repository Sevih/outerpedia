{
  "name": "outerpedia",
  "version": "0.1.8",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm clean:all && tsx scripts/dev-refresh.ts && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit && tsc --noEmit -p datagen/tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "datagen:pull": "tsx datagen/extract/pull-gamedata.ts",
    "datagen:extract": "tsx datagen/extract/extract.ts",
    "datagen:convert": "tsx datagen/templates/convert.ts",
    "datagen:build": "tsx datagen/build.ts",
    "datagen:patch": "tsx datagen/refresh.ts",
    "datagen:regen": "pnpm datagen:build && pnpm datagen:promote --apply",
    "datagen:promote": "tsx datagen/promote.ts",
    "datagen:version-boss": "tsx datagen/version-boss.ts",
    "getNews": "tsx scripts/get-news.ts",
    "stamp:guides": "tsx scripts/stamp-guides.ts",
    "commit": "tsx scripts/commit.ts",
    "prepare": "lefthook install || true",
    "datagen:extract-entity": "tsx datagen/extractor/run.ts",
    "datagen:seed-curated": "tsx datagen/curated/seed.ts",
    "clean": "node -e \"for(const f of ['.next'])require('fs').rmSync(f,{recursive:true,force:true})\"",
    "clean:all": "node -e \"for(const f of ['.next','node_modules'])require('fs').rmSync(f,{recursive:true,force:true})\" && pnpm install",
    "datagen:coherence": "tsx datagen/extractor/coherence.ts",
    "assets:collect": "tsx datagen/assets/collect.ts",
    "assets:push": "node scripts/assets-push.mjs",
    "images": "pnpm assets:collect && pnpm assets:push",
    "datagen:face-layout": "python datagen/assets/extract-face-layout.py"
  },
  "dependencies": {
    "@radix-ui/react-hover-card": "^1.1.18",
    "next": "16.2.10",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cheerio": "^1.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "lefthook": "^2.1.9",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0.8",
    "sharp": "^0.35.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
