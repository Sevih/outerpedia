          }
        },
        {
          "characters": ["Gnosis Beth"],
          "reason": {
            "en": "Stacks {D/ETERNAL_BLEEDING} on all enemies and detonates it for heavy damage, while granting {B/BT_STEALTHED} to allies.",
            "jp": "全体に{D/ETERNAL_BLEEDING}を蓄積して起爆し大ダメージを与え、味方に{B/BT_STEALTHED}を付与。",
            "kr": "모든 적에게 {D/ETERNAL_BLEEDING}를 축적한 뒤 폭발시켜 큰 피해를 주고, 아군에게 {B/BT_STEALTHED}를 부여.",
            "zh": "在所有敌人身上叠加{D/ETERNAL_BLEEDING}并引爆造成大量伤害，同时为队友提供{B/BT_STEALTHED}。",
            "fr": "Empile {D/ETERNAL_BLEEDING} sur tous les ennemis et le détone pour de lourds dégâts, tout en accordant {B/BT_STEALTHED} à l'équipe."
          }
        },
        {
          "characters": ["Akari"],
          "reason": {
            "en": "Offers {D/BT_SEALED} and {D/BT_EXTEND_DEBUFF}.",
            "jp": "{D/BT_SEALED}と{D/BT_EXTEND_DEBUFF}を提供。",
            "kr": "{D/BT_SEALED}와 {D/BT_EXTEND_DEBUFF}를 제공.",
            "zh": "提供{D/BT_SEALED}和{D/BT_EXTEND_DEBUFF}。",
            "fr": "Offre {D/BT_SEALED} et {D/BT_EXTEND_DEBUFF}."
          }
        },
        {
          "characters": ["Notia"],
          "reason": {
            "en": "{D/BT_DOT_POISON} limits the boss's turn count.",
            "jp": "{D/BT_DOT_POISON}でボスのターン数を制限。",
            "kr": "{D/BT_DOT_POISON}으로 보스의 턴 수를 제한.",
            "zh": "{D/BT_DOT_POISON}限制首领的行动次数。",
            "fr": "{D/BT_DOT_POISON} limite le nombre de tours du boss."
          }
        },
        {
          "characters": ["Tamara", "Valentine"],
          "reason": {
            "en": "Provides {B/BT_CALL_BACKUP} and {B/BT_STAT|ST_CRITICAL_RATE}.",
            "jp": "{B/BT_CALL_BACKUP}と{B/BT_STAT|ST_CRITICAL_RATE}を提供。",
            "kr": "{B/BT_CALL_BACKUP}와 {B/BT_STAT|ST_CRITICAL_RATE}를 제공.",
            "zh": "提供{B/BT_CALL_BACKUP}和{B/BT_STAT|ST_CRITICAL_RATE}。",
            "fr": "Fournit {B/BT_CALL_BACKUP} et {B/BT_STAT|ST_CRITICAL_RATE}."
          }
        },
        {
          "characters": ["Luna"],
          "reason": {
            "en": "Offers {B/BT_CALL_BACKUP} and {D/BT_SEALED}.",
            "jp": "{B/BT_CALL_BACKUP}と{D/BT_SEALED}を提供。",
            "kr": "{B/BT_CALL_BACKUP}와 {D/BT_SEALED}를 제공.",
            "zh": "提供{B/BT_CALL_BACKUP}和{D/BT_SEALED}。",
            "fr": "Offre {B/BT_CALL_BACKUP} et {D/BT_SEALED}."
          }
        },
        {
          "characters": ["Ryu Lion"],
          "reason": {
            "en": "Provides {D/BT_FIXED_DAMAGE} and {B/BT_STAT|ST_SPEED}.",
            "jp": "{D/BT_FIXED_DAMAGE}と{B/BT_STAT|ST_SPEED}を提供。",
            "kr": "{D/BT_FIXED_DAMAGE}와 {B/BT_STAT|ST_SPEED}를 제공.",
            "zh": "提供{D/BT_FIXED_DAMAGE}和{B/BT_STAT|ST_SPEED}。",
            "fr": "Fournit {D/BT_FIXED_DAMAGE} et {B/BT_STAT|ST_SPEED}."
          }
        },
        {
          "characters": ["Omega Nadja"],
          "reason": {
            "en": "Provides {B/BT_BARRIER} for survival. Caution: breaking with her prevents K from dealing damage.",
            "jp": "生存のための{B/BT_BARRIER}を提供。注意：彼女でブレイクするとKがダメージを与えられなくなります。",
            "kr": "생존을 위한 {B/BT_BARRIER}를 제공. 주의: 그녀로 브레이크하면 K가 피해를 줄 수 없습니다.",
            "zh": "提供{B/BT_BARRIER}保障生存。注意：用她击破会导致K无法造成伤害。",
            "fr": "Fournit {B/BT_BARRIER} pour la survie. Attention : break avec elle empêche K d'infliger des dégâts."
          }
        },
        {
          "characters": ["Demiurge Vlada"],
          "reason": {
            "en": "Applies {D/BT_REMOVE_BUFF} and reduces boss priority gain at transcend. Caution: breaking with her prevents K from dealing damage.",
            "jp": "{D/BT_REMOVE_BUFF}を付与し、超越でボスの行動ゲージ上昇を減少。注意：彼女でブレイクするとKがダメージを与えられなくなります。",
            "kr": "{D/BT_REMOVE_BUFF}를 적용하고 초월로 보스의 행동 게이지 증가를 감소. 주의: 그녀로 브레이크하면 K가 피해를 줄 수 없습니다.",
            "zh": "施加{D/BT_REMOVE_BUFF}并通过突破减少首领行动值增加。注意：用她击破会导致K无法造成伤害。",
            "fr": "Applique {D/BT_REMOVE_BUFF} et réduit le gain de priority du boss en transcend. Attention : break avec elle empêche K d'infliger des dégâts."
          }
        }
      ]
