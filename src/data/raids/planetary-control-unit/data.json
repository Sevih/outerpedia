          "setup": [
            [
              "Ember"
            ]
          ],
          "note": [
            {
              "type": "p",
              "string": "T4 {AS/Revenge} and {I-T/Vanguard's Charm}, stack {S/ATK}. The geas that gives 150 {S/EFF} is doubled by her EE so you only need around 218 {S/EFF}, easily achieved by glove slot alone."
            },
            {
              "type": "p",
              "string": "Use S3 whenever possible unless you need the shield to survive. If the boss doesn't drop you below 50% on your first turn, use burst 1 after."
            },
            {
              "type": "p",
              "string": "Must be solo (no other units in the team) because the boss hits much harder if she gets a kill."
            },
            {
              "type": "p",
              "string": "If you overkill the boss, you can turn off the {E/Fire} ATK+ geas for more points."
            }
          ]
        },
        "team2": {
          "label": "Burn Team",
          "icon": "SC_Buff_detonate.webp",
          "video": {
            "videoId": "xhTt8Ecj_28",
            "title": "Planetary Control Unit Epsilon Raid - Burn Team, 23.88m dmg, 110% multiplier (50.15m points)",
            "author": "Tango"
          },
          "geas-active": {
            "bonus": [
              44,
              50,
              107
            ],
            "malus": [
              86,
              106,
              87,
              81,
              105,
              5
            ]
          },
          "setup": [
            [
              "Maxie"
            ],
            [
              "Roxie"
            ],
            [
              "Akari"
            ],
            [
              "Vlada"
            ]
          ],
          "note": [
            {
              "type": "p",
              "string": "Break the boss on turn 15 before she uses her S3 nuke. If you do, it's 0 damage taken, meaning it scales into higher stages with no issues."
            },
            {
              "type": "p",
              "string": "Turn order: {P/Akari} (294 {S/SPD}) > {P/Maxie} (276 {S/SPD}) > {P/Roxie} (263 {S/SPD}) > {P/Vlada} (126 {S/SPD}). Lots of flexibility as long as {P/Maxie} and {P/Roxie} are fast enough and {P/Akari} outspeeds the boss."
            },
            {
              "type": "p",
              "string": "{P/Maxie}: 276 {S/SPD}, T4 {I-W/Heartunder's Blade}, {I-T/Executioner's Charm} +10, 6* transcendence, EE+0 minimum."
            },
            {
              "type": "p",
              "string": "{P/Roxie}: 263 {S/SPD}, T4 {I-A/Dies Irae}, {I-T/Executioner's Charm} +10, 6* transcendence, EE+10 minimum."
            },
            {
              "type": "p",
              "string": "{P/Vlada}: 126 {S/SPD}, any AP Boosting charm, stack {S/ATK}. Use {I-W/Phantasm Necrosis} to go below base {S/SPD}. Can be min {S/SPD} (96) but at 126, she moves as early as possible while only getting 2 turns, giving her S3 burns more opportunities to be extended."
            },
            {
              "type": "p",
              "string": "{P/Akari}: 294 {S/SPD}, EE+0, 518+ {S/EFF} or 259+ with T4 {I-W/Briareos's Recklessness [Ranger]}. If you have 259+ {S/EFF} on both {P/Roxie} and {P/Maxie}, you can skip the resilience down. 6* transcendence with 2 {AS/Bursting} optional for turn 1 burst 2 to nullify defence buff."
            },
            {
              "type": "p",
              "string": "If you overkill the boss, you can turn off the {E/Fire} ATK+ geas for more points."
            }
          ]
        },
        "team3": {
          "label": "Mero + Claire",
          "icon": "fire.webp",
          "video": {
            "videoId": "MQdqPgT6LpU",
            "title": "Planetary Control Unit Epsilon Raid - Solo Mero - 4.12m Dmg, 195% multiplier",
